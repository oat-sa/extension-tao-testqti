msgstr "Povoliť výber"

msgid "Enable Skipping Ahead"
msgstr "Povoliť preskakovanie dopredu"

msgid "Enable text to speech"
msgstr "Povoliť premenu textu na reč"

msgid "Enable the item review screen / navigator."
msgstr "Povoliť obrazovku/navigátor kontroly položiek."

