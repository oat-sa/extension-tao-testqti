msgid "\"Lowest Grade Achieved\" sets the final test grade as the lowest score among all test variables using the same scale."
msgstr "„Najnižšia dosiahnutá známka“ nastavuje konečnú známku testu ako najnižšie skóre spomedzi všetkých testových premenných s použitím rovnakej stupnice."

msgid "%s to answer %s"
msgstr "%s na odpoveď %s"

msgid "%title% - Translation (%lang%)"
msgstr "%title% - Preklad (%lang%)"

msgid "(Visual) Clear all active highlights"
msgstr "(Vizuálne) Vymazať všetky aktívne zvýraznenia"

msgid "(Visual) Highlight Text"
msgstr "(Vizuálne) Zvýraznenie textu"

msgid "A concurrent delivery has been detected. Please use the last open session. The present window can be closed."
msgstr "Bola zistená súbežná dodávka. Použite prosím posledný otvorený záznam. Toto okno môžete zavrieť."

msgid "A human interpretation of the variable's value."
msgstr "Ľudská interpretácia hodnoty premennej."

msgid "A QTI Item involved in the QTI Test '%s' could not be compiled."
msgstr "Položku QTI zapojenú do testu QTI „%s“ nebolo možné skompilovať."

msgid "A QTI Test must contain at least one QTI Item to be compiled. None found."
msgstr "Test QTI musí obsahovať aspoň jednu položku QTI, aby sa dal zostaviť. Žiadna sa nenašla."

msgid "A qti testpackage"
msgstr "Testový balík QTI"

msgid "A remote resource referenced in QTI test '%s' could not be retrieved."
msgstr "Vzdialený zdroj uvedený v teste QTI '%s' sa nepodarilo načítať."

msgid "A response to every question in this item is required."
msgstr "Je potrebné odpovedať na každú otázku v tejto položke."

msgid "A response to this item is invalid."
msgstr "Odpoveď na túto položku je neplatná."

msgid "A response to this item is required."
msgstr "Na túto položku je potrebné odpovedať."

msgid "A valid response to this item is required."
msgstr "Na túto položku je vyžadovaná platná odpoveď."

msgid "A visible section is one that is identifiable by the candidate."
msgstr "Viditeľná časť je tá, ktorú účastník testu dokáže identifikovať."

msgid "Accessibility tool that enables Test Taker to have the item content read aloud."
msgstr "Nástroj na zjednodušenie prístupu, ktorý umožňuje účastníkovi testu nechať si nahlas prečítať obsah položky."

msgid "Activated"
msgstr "Aktivované"

msgid "add a new weight"
msgstr "pridať novú váhu"

msgid "Add a Path"
msgstr "Pridať cestu"

msgid "Add a Prerequisite"
msgstr "Pridať Predpoklad"

msgid "Add a zip file containing QTI/APIP tests and items"
msgstr "Pridajte ZIP súbor obsahujúci testy a položky QTI/APIP"

msgid "Add an outcome declaration"
msgstr "Pridajte definovanie výsledku"

msgid "Add selected item(s) here."
msgstr "Sem pridajte vybraté položky."

msgid "Add Subsection"
msgstr "Pridať Podsekciu"

msgid "Add the source file"
msgstr "Pridajte zdrojový súbor"

msgid "After you complete the section it would be impossible to return to this section to make changes. Are you sure you want to end the section?"
msgstr "Po dokončení tejto sekcie nebude možné sa do nej vrátiť a vykonať zmeny. Naozaj chcete túto sekciu ukončiť?"

msgid "All"
msgstr "Všetky"

msgid "Allow a Test Taker to print out the item."
msgstr "Umožnite účastníkovi testu vytlačiť si položku."

msgid "Allow Comment"
msgstr "Povoliť komentár"

msgid "Allow Review"
msgstr "Povoliť kontrolu"

msgid "Allow Section Skipping"
msgstr "Povoliť preskakovanie sekcií"

msgid "Allow Skipping"
msgstr "Povoliť preskakovanie"

msgid "Allow skipping of the current section."
msgstr "Povoliť preskočenie aktuálnej sekcie."

msgid "Allow Test-taker to playback media files associated according to APIP protocol to item content."
msgstr "Umožniť účastníkovi testu prehrávať multimediálne súbory priradené k obsahu položky podľa protokolu APIP."

msgid "Allow the candidate to review his answers."
msgstr "Umožnite účastníkovi testu skontrolovať si svoje odpovede."

msgid "Allow the test-taker to eliminate / strikethrough answers in choice interactions."
msgstr "Umožnite účastníkovi testu vynechať/prečiarknuť odpovede v interakciách s možnosťami výberu."

msgid "Allow the test-taker to highlight parts of the item text."
msgstr "Umožnite účastníkovi testu zvýrazniť časti textu položky."

msgid "Allow the test-taker to mask and unmask answers in choice interactions."
msgstr "Umožnite účastníkovi testu maskovať a odmaskovať odpovede v rámci interakcií s možnosťami výberu."

msgid "Allow the test-taker to mask parts of the item with a movable mask."
msgstr "Umožnite testovanému maskovať časti položky pohyblivou maskou."

msgid "Allow the test-taker to use a basic calculator."
msgstr "Umožnite účastníkovi testu používať základnú kalkulačku."

msgid "Allow the test-taker to use a calculator respecting the order of operations (BODMAS)."
msgstr "Umožnite účastníkovi testu používať kalkulačku bez porušenia poradia operácií (BODMAS)."

msgid "Allow the test-taker to use a movable magnifier tool."
msgstr "Umožnite účastníkovi testu použiť pohyblivú lupu."

msgid "Allow the test-taker to use a scientific calculator."
msgstr "Umožnite účastníkovi testu použiť vedeckú kalkulačku."

msgid "Allow the test-taker to visually isolate a line of text."
msgstr "Umožnite účastníkovi testu vizuálne oddeliť riadok textu."

msgid "Allows Test-taker to zoom in and out the item content."
msgstr "Umožňuje účastníkovi testu priblížiť a oddialiť obsah položky."

msgid "Also compute the score per categories"
msgstr "Vypočítajte tiež skóre podľa jednotlivých kategórií"

msgid "An error occured while retrieving items"
msgstr "Pri načítavaní položiek sa vyskytla chyba"

msgid "An error occurred during results submission. Please retry."
msgstr "Počas odosielania výsledkov sa vyskytla chyba. Skúste to znova."

msgid "An error occurred during the test initialization!"
msgstr "Počas inicializácie testu sa vyskytla chyba!"

msgid "An error occurred during the test, please content your administrator."
msgstr "Počas testu sa vyskytla chyba, informujte, prosím, svojho administrátora."

msgid "An error occurred while loading the original test."
msgstr "Pri načítavaní pôvodného testu sa vyskytla chyba."

msgid "An error occurred!"
msgstr "Vyskytla sa chyba!"

msgid "An error occurs, please contact your administrator"
msgstr "Vyskytla sa chyba, kontaktujte, prosím, svojho administrátora."

msgid "An invisible section with a parent that is subject to shuffling can specify whether or not its children, which will appear to the candidate as if they were part of the parent, are shuffled as a block or mixed up with the other children of the parent section."
msgstr "Neviditeľná sekcia, ktorej nadradená sekcia podlieha náhodnému usporiadaniu, môže určiť, či sa jej podsekcie (ktoré sa účastníkovi testu budú zdať ako súčasť nadradenej sekcie) budú usporiadať ako jeden blok, alebo sa premiešajú s ostatnými podsekciami nadradenej sekcie."

msgid "An item involved in the test cannot be read or is not QTI compliant."
msgstr "Položku zaradenú do testu nie je možné prečítať alebo nie je v súlade s QTI."

msgid "An item involved in the test cannot be written."
msgstr "Položka, ktorá je súčasťou testu, sa nedá zapísať."

msgid "An optional link to an extended interpretation of the outcome variable."
msgstr "Voliteľný odkaz na podrobnejší výklad premennej výsledku."

msgid "An unknown error occured while compiled QTI Test '%s'."
msgstr "Pri kompilácii QTI testu '%s' sa vyskytla neznáma chyba."

msgid "An unknown error occured while compiling QTI test '%s'."
msgstr "Pri kompilácii QTI testu '%s' sa vyskytla neznáma chyba."

msgid "An unrecoverable error occurred. Your test session will be paused."
msgstr "Vyskytla sa neopraviteľná chyba. Váš testovací záznam bude pozastavený."

msgid "and"
msgstr "a"

msgid "and flagged %s of them"
msgstr "a označil %s z nich"

msgid "and you flagged %s item(s) that you can review now"
msgstr "a označili ste %s položiek, ktoré môžete teraz skontrolovať"

msgid "Answer Eliminator"
msgstr "Eliminátor odpovedí"

msgid "Answer Masking"
msgstr "Maskovanie odpovedí"

msgid "Answered"
msgstr "Zodpovedané"

msgid "APIP Text To Speech"
msgstr "API Premena textu na reč "

msgid "Are you sure you want to clear your answer and go to the next item? You will not be able to go back and provide an answer."
msgstr "Naozaj chcete vymazať svoju odpoveď a prejsť na ďalšiu položku? Nebudete sa môcť vrátiť späť a poskytnúť odpoveď."

msgid "Are you sure you want to end the test?"
msgstr "Naozaj chcete ukončiť test?"

msgid "Are you sure you want to go to the next item? You will not be able to go back and change your answer."
msgstr "Naozaj chcete prejsť na ďalšiu položku? Nebudete sa môcť vrátiť späť a zmeniť svoju odpoveď."

msgid "Are you sure you want to go to the next item? You will not be able to go back and provide an answer."
msgstr "Naozaj chcete prejsť na ďalšiu položku? Nebudete sa môcť vrátiť späť a poskytnúť odpoveď."

msgid "Are you sure you want to go to the next item? You will not be able to go back."
msgstr "Naozaj chcete prejsť na ďalšiu položku? Nebudete sa môcť vrátiť späť."

msgid "Area Masking"
msgstr "Maskovanie oblasti"

msgid "Associate a blueprint to a section allow you to validate this section against the specified blueprint."
msgstr "Priradením návrhu k sekcii môžete túto sekciu schváliť na základe zadaného návrhu."

msgid "Associate Blueprint"
msgstr "Návrh asociácie"

msgid "At least one mandatory parameter was required but found missing in your request"
msgstr "Vo vašej požiadavke chýbal aspoň jeden povinný parameter"

msgid "At least one manually graded outcome variable with a grading scale is required for this mode."
msgstr "Pre tento režim je potrebná aspoň jedna premenná výsledku, ktorá sa hodnotí manuálne pomocou hodnotiacej stupnice."

msgid "Author"
msgstr "Autor"

msgid "Auxiliary file not found at location \"%s\"."
msgstr "Pomocný súbor sa nenašiel na mieste „%s“."

msgid "Black on Cream"
msgstr "Čierna na Krémovej"

msgid "Black on Light Blue"
msgstr "Čierna na Svetlomodrej"

msgid "Black on Light Magenta"
msgstr "Čierna na Svetlopurpurovej"

msgid "Black on White"
msgstr "Čierna na Bielom"

msgid "Bookmark question"
msgstr "Pridať otázku do záložiek"

msgid "Bookmark the current question for later review"
msgstr "Pridať aktuálnu otázku do záložiek na neskoršiu kontrolu"

msgid "Bookmarked question %s"
msgstr "Otázka v záložkách %s"

msgid "Branch rule validation error: %s"
msgstr "Chyba overenia pravidla vetvenia: %s"

msgid "Calculator"
msgstr "Kalkulačka"

msgid "Calculator BODMAS"
msgstr "Kalkulačka BODMAS"

msgid "Can not playback media file!"
msgstr "Nie je možné prehrať multimediálny súbor!"

msgid "Cancel"
msgstr "Zrušiť"

msgid "CANCEL"
msgstr "ZRUŠIŤ"

msgid "Candidate"
msgstr "Účastník testu"

msgid "Cardinality"
msgstr "Kardinalita"

msgid "Categories"
msgstr "Kategórie"

msgid "Category name not allowed"
msgstr "Názov kategórie nie je povolený"

msgid "Category score"
msgstr "Hodnotenie kategórie"

msgid "Change the current color preset"
msgstr "Zmena aktuálnej predvoľby farieb"

msgid "Checking this box prevents the test-taker from navigating to other items until the current item constraints, if any, are met. Unchecking this box will allow free navigation even if the responses don't comply with the item constraints set."
msgstr "Zaškrtnutím tohto políčka zabránite účastníkovi testu v prechádzaní na ďalšie položky, kým nebudú splnené prípadné obmedzenia aktuálnej položky. Odškrtnutím tohto políčka povolíte voľné prechádzanie medzi položkami, aj keď odpovede nespĺňajú nastavené obmedzenia položky."

msgid "Class"
msgstr "Priečinok"

msgid "Class successfully created."
msgstr "Priečinok bol úspešne vytvorený."

msgid "Clear all active highlights"
msgstr "Vymazať všetky aktívne zvýraznenia"

msgid "Clear Highlights"
msgstr "Vymazať zvýraznenia"

msgid "Click \"%s\" to continue"
msgstr "Pokračujte kliknutím na „%s“"

msgid "Click \"%s\" to continue."
msgstr "Pokračujte kliknutím na „%s“"

msgid "Click to speak"
msgstr "Kliknite a hovorte"

msgid "Close"
msgstr "Zatvoriť"

msgid "Close Magnifier"
msgstr "Zatvoriť lupu"

msgid "Close the mask"
msgstr "Zatvorte masku"

msgid "Close this Section"
msgstr "Zatvoriť túto Sekciu"

msgid "Collapse the review panel"
msgstr "Zatvoriť panel kontroly"

msgid "Comment"
msgstr "Komentár"

msgid "Completed items"
msgstr "Dokončené položky"

msgid "Connected to server"
msgstr "Pripojené k serveru"

msgid "CONTINUE TO THE NEXT SECTION"
msgstr "POKRAČUJTE NA ĎALŠIU SEKCIU"

msgid "Contrast"
msgstr "Kontrast"

msgid "Controls the contribution of an individual item score to the overall test score."
msgstr "Určuje, akým podielom sa bodové hodnotenie jednotlivých položiek podieľa na celkovom výsledku testu."

msgid "Controls the maximum number of attempts allowed. 0 means unlimited."
msgstr "Určuje maximálny povolený počet pokusov. Hodnota 0 znamená neobmedzený počet."

msgid "Covers parts of the item"
msgstr "Zakrýva časti položky"

msgid "Custom"
msgstr "Vlastné"

msgid "custom categories"
msgstr "vlastné kategórie"

msgid "Custom outcome processing. No changes will be made to the existing rules."
msgstr "Vlastné spracovanie výsledkov. Existujúce pravidlá nebudú zmenené."

msgid "Cut score"
msgstr "Hraničná hodnota"

msgid "Cut score (pass ratio)"
msgstr "Hraničná hodnota (miera úspešnosti)"

msgid "Define the status of the translation."
msgstr "Definujte stav prekladu."

msgid "Defines the maximum magnitude of numeric outcome variables, the maximum must be a positive value and the minimum may be negative."
msgstr "Určuje maximálnu hodnotu numerických výsledných premenných; maximálna hodnota musí byť kladná a minimálna hodnota môže byť záporná."

msgid "Delete"
msgstr "Odstrániť"

msgid "Delete prerequisite"
msgstr "Odstrániť predpoklad"

msgid "Delete rule"
msgstr "Odstrániť pravidlo"

msgid "Disable validation"
msgstr "Vypnúť overenie"

msgid "Disconnected from server"
msgstr "Odpojené od servera"

msgid "Display a warning before the test-taker ends a test part and there are still items left unanswered or marked for review."
msgstr "Zobraziť upozornenie predtým, ako účastník testu ukončí časť testu a stále zostanú nezodpovedané alebo označené položky na kontrolu."

msgid "Display a warning before the test-taker ends the test part."
msgstr "Zobraziť upozornenie predtým, ako účastník testu ukončí časť testu."

msgid "Display a warning before the test-taker ends the test."
msgstr "Zobraziť upozornenie predtým, ako účastník testu ukončí test."

msgid "Display a warning before the test-taker skips the section. Requires the Section Skipping option."
msgstr "Zobraziť upozornenie predtým, ako účastník testu preskočí danú sekciu. Vyžaduje sa možnosť Preskočenie sekcie."

msgid "Display End Test Warning"
msgstr "Zobraziť varovanie o ukončení testu"

msgid "Display Next Part Warning"
msgstr "Zobraziť upozornenie o ďalšej časti"

msgid "Display Next Section Warning"
msgstr "Zobraziť upozornenie o ďalšej sekcii"

msgid "Display Unanswered Warning"
msgstr "Zobraziť upozornenie na nezodpovedané otázky"

msgid "Displayed label"
msgstr "Zobrazený štítok"

msgid "Displays a customisable magnifier"
msgstr "Zobrazuje prispôsobiteľnú lupu"

msgid "Do not bookmark the current question for later review"
msgstr "Neukladať aktuálnu otázku do záložiek na neskoršiu kontrolu"

msgid "Do not flag the current item for later review"
msgstr "Neoznačovať aktuálnu položku na neskoršiu kontrolu"

msgid "Do not rename it."
msgstr "Nepremenujte to."

msgid "Do not show alert on timeout"
msgstr "Nezobrazovať upozornenie pred uplynutím časového limitu"

msgid "Do you want to apply the category \"%s\" to all included items?"
msgstr "Chcete použiť kategóriu „%s“ na všetky zahrnuté položky?"

msgid "Don\\'t save"
msgstr "Ne/ukladať"

msgid "Download"
msgstr "Stiahnuť"

msgid "Download the pupil responses and submit manually."
msgstr "Stiahnite si odpovede žiakov a odošlite ich manuálne."

msgid "Each condition below is evaluated, starting from the top, by comparing the variable content with a specific value, using the operator. As soon as a condition is fulfilled, the test taker is redirected to the corresponding target. If no condition is fulfilled, the test taker is presented with the next test part in the natural order."
msgstr "Každá z nižšie uvedených podmienok sa vyhodnocuje od začiatku tak, že sa obsah premennej porovná s konkrétnou hodnotou pomocou operátora. Akonáhle je podmienka splnená, účastník testu je presmerovaný na príslušný cieľ. Ak nie je splnená žiadna podmienka, účastníkovi testu sa v prirodzenom poradí zobrazí ďalšia časť testu."

msgid "Each prerequisite below is evaluated by comparing the variable content with a specific value, using the operator. If all the prerequisites are fulfilled, this test part is presented. Otherwise, this test part is skipped."
msgstr "Každá z nižšie uvedených podmienok sa vyhodnocuje porovnaním obsahu premennej s konkrétnou hodnotou pomocou operátora. Ak sú splnené všetky podmienky, táto časť testu sa zobrazí. V opačnom prípade sa táto časť testu preskočí."

msgid "Edit"
msgstr "Upraviť"

msgid "Eliminate choices"
msgstr "Eliminujte možnosti"

msgid "Enable Mark for Review"
msgstr "Povoliť označenie na kontrolu"

msgid "Enable mark for review of items. Requires the Review Screen option."
msgstr "Povoliť označovanie na kontrolu položiek. Vyžaduje sa možnosť Obrazovka Kontroly."

msgid "Enable Review Screen"
msgstr "Povoliť obrazovku Kontroly"

